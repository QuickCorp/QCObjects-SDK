{
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "module": "NodeNext",
    "rootDir": "./",
    "allowJs": true,
    "outDir": "build/spec",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "types": [
        "src/types/global/index.d.ts"
      ]
    }
  },
  "include": [
    "spec/**/*",
    "src/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "**/*.js",
    "src/index.mts",
    "src/index.cts",
    "node_modules",
    "node_modules/**/*",
    "**/node_modules/*",
    "public/types"
  ],

}